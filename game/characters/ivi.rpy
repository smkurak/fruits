# ========================
# СЦЕНЫ С ИВИ
# ========================
# Точка входа — общий label visit_router в game/characters.rpy,
# который выставляет current_girl/n и прыгает сюда по стадии.
#
# Арт и музыка ещё не готовы — до появления файлов по путям из реестра
# (game/characters.rpy) спрайт и фон рисуются плейсхолдером Ren'Py.
# Как только файлы появятся на диске под теми же именами, ничего здесь
# менять не нужно. Музыка закомментирована — раскомментировать, когда
# появятся треки ivi_music_10/20/30.mp3.

# ----------------------------------------
# ПЕРВЫЙ ВИЗИТ / СТАДИЯ 1 (affection 0–14)
# ----------------------------------------

label ivi_stage1:
    scene bg ivi with fade
    # play music "audio/music/ivi_music_10.mp3" fadein 2.0

    show ivi at center with dissolve

    $ _first_visit = not has_flag("ivi_stage1_seen")
    $ set_flag("ivi_stage1_seen")

    if _first_visit:
        "Она сидит на мшистом камне у ручья, наматывая тонкую лиану на пальцы. Услышав шаги, вздрагивает и вжимает голову в плечи, будто хочет исчезнуть в листве."
        n "...Ты не туда свернул. Тропа обратно — там."

        "Она снова смотрит в воду, будто разговор уже закончен — но не уходит и не просит уйти тебя."

        n "...Хотя. Можешь остаться. Если хочешь. Не обязательно."
    else:
        n "...Ты снова тут. Я... не против. Наверное."

    $ reset_choices_if_exhausted("ivi", 1, 4)

    menu:
        "Я не заблудился. Я искал тебя." if choice_open("ivi", 1, 0):
            $ use_choice("ivi", 1, 0)
            $ add_affection("ivi", 6)
            n "...Зачем? Меня обычно... не ищут."
            n "...Не знаю, что на это ответить. Наверное, спасибо. Наверное."

        "Извини, я уйду, если мешаю." if choice_open("ivi", 1, 1):
            $ use_choice("ivi", 1, 1)
            $ add_affection("ivi", 8)
            n "...Нет. Не обязательно. Просто — неожиданно."
            n "...Обычно люди не спрашивают. Просто уходят. Или просто остаются."

        "Тут красиво. Не думал, что здесь кто-то живёт." if choice_open("ivi", 1, 2):
            $ use_choice("ivi", 1, 2)
            $ add_affection("ivi", 3)
            n "Красиво? ...Наверное. Я не думала об этом так."
            n "...Я привыкла, что это просто место, где меня не найдут. Красота — это что-то новое."

        "Странное место для пряток." if choice_open("ivi", 1, 3):
            $ use_choice("ivi", 1, 3)
            $ add_affection("ivi", -3)
            n "...Я не пряталась. Просто сижу. Тебе обязательно это комментировать?"
            n "...Извини. Резко получилось. Просто это слово... задело."

    if _first_visit:
        n "...Обычно сюда никто не заходит. Значит, ты либо потерялся, либо..."
        "Она не заканчивает фразу. Просто снова опускает взгляд на лиану в руках и позволяет тишине договорить за неё."

    # Проверяем, достигли ли новой стадии
    if get_affection("ivi") >= 15:
        $ renpy.notify("✨ Иви держится чуть спокойнее рядом с тобой.")
    else:
        $ renpy.notify("Иви явно рада, что ты не задаёшь больше вопросов.")

    hide ivi with dissolve
    jump return_to_map


# ----------------------------------------
# ВТОРОЙ ВИЗИТ / СТАДИЯ 2 (affection 15–34)
# ----------------------------------------

label ivi_stage2:
    scene bg ivi with fade
    # play music "audio/music/ivi_music_20.mp3" fadein 2.0

    show ivi at center with dissolve

    $ _first_visit = not has_flag("ivi_stage2_seen")
    $ set_flag("ivi_stage2_seen")

    if _first_visit:
        "Ручей журчит тише обычного. Иви уже не шарахается на звук шагов — просто поднимает взгляд и снова быстро отводит его."
        n "...Ты опять здесь. Я почти... привыкла."

        "Она подвигается на камне — освобождая немного места рядом с собой, не глядя на тебя при этом."

        n "...Тут только один камень. Не то чтобы я специально."
    else:
        n "...Опять пришёл. Я почти ждала."

    $ reset_choices_if_exhausted("ivi", 2, 4)

    menu:
        "Я подумал о тебе и решил зайти." if choice_open("ivi", 2, 0):
            $ use_choice("ivi", 2, 0)
            $ add_affection("ivi", 10)
            n "...Правда? Никто раньше не думал обо мне вот так. Просто так."
            n "...Мне нужно время, чтобы к этому привыкнуть. Не отменяй сказанное, ладно?"

        "Хотел узнать, как твой день." if choice_open("ivi", 2, 1):
            $ use_choice("ivi", 2, 1)
            $ add_affection("ivi", 12)
            n "Мой день... тихий. Как обычно. Но сегодня чуть менее тихий."
            n "...Из-за тебя, если что. Это не жалоба."

        "Можно я посижу рядом? Не обязательно говорить." if choice_open("ivi", 2, 2):
            $ use_choice("ivi", 2, 2)
            $ add_affection("ivi", 7)
            n "...Можно. Мне так даже проще."
            n "...Молчать вдвоём оказалось не так страшно, как я думала."

        "Ты всегда такая молчаливая?" if choice_open("ivi", 2, 3):
            $ use_choice("ivi", 2, 3)
            $ add_affection("ivi", -4)
            n "...Прости, что не развлекаю тебя разговором. Не все умеют иначе."
            n "...Можешь уйти, если скучно. Я не обижусь. Наверное."

    if _first_visit:
        n "...Не думала, что кто-то станет возвращаться сюда просто так."
        "Она чертит пальцем узор на мокром камне, не поднимая глаз, пока ты уходишь."

    if get_affection("ivi") >= 35:
        $ renpy.notify("✨ Иви понемногу выходит из тени. Взгляд стал увереннее.")
    else:
        $ renpy.notify("Иви всё ещё осторожна, но не убегает.")

    hide ivi with dissolve
    jump return_to_map


# ----------------------------------------
# ТРЕТИЙ ВИЗИТ / СТАДИЯ 3 (affection 35–59)
# ----------------------------------------

label ivi_stage3:
    scene bg ivi with fade
    # play music "audio/music/ivi_music_30.mp3" fadein 2.0

    show ivi at center with dissolve

    $ _first_visit = not has_flag("ivi_stage3_seen")
    $ set_flag("ivi_stage3_seen")

    if _first_visit:
        "Тропинка к её месту стала заметнее — будто кто-то стал протаптывать её чаще. Иви сидит не на камне, а прямо на траве рядом, и впервые не отводит взгляд сразу."
        n "...Я слышала тебя издалека. И не спряталась. Наверное, это что-то значит."

        "Она смотрит прямо на тебя — непривычно долго для неё — прежде чем снова опустить взгляд, но уже не так поспешно."

        n "...Прости. Просто пытаюсь запомнить, как это — не отворачиваться."
    else:
        n "...Ты вернулся. Я рада — просто не умею это показывать громко."

    $ reset_choices_if_exhausted("ivi", 3, 4)

    menu:
        "Значит, я перестал быть чужаком." if choice_open("ivi", 3, 0):
            $ use_choice("ivi", 3, 0)
            $ add_affection("ivi", 12)
            n "...Возможно. Хотя я всё ещё не уверена, что это хорошо."
            n "...Быть открытой пугает больше, чем прятаться. Но, кажется, я готова попробовать."

        "Мне нравится, какая ты. Даже такая тихая." if choice_open("ivi", 3, 1):
            $ use_choice("ivi", 3, 1)
            $ add_affection("ivi", 14)
            n "...Даже такая? Обычно это говорят с 'но' в конце."
            n "...Спасибо, что не добавил его."

        "Расскажи мне о себе. Я никуда не тороплюсь." if choice_open("ivi", 3, 2):
            $ use_choice("ivi", 3, 2)
            $ add_affection("ivi", 10)
            n "...Никто раньше не говорил мне это. Обычно тороплюсь я. Убежать."
            n "...Может, в этот раз получится досидеть до конца рассказа."

        "Тебе не кажется, что ты слишком долго прячешься?" if choice_open("ivi", 3, 3):
            $ use_choice("ivi", 3, 3)
            $ add_affection("ivi", -5)
            n "...Может быть. Но это не значит, что я готова услышать это от тебя."
            n "...Дай мне дойти самой. Так надёжнее."

    if _first_visit:
        n "...Останься ненадолго. Тут никто не мешает."
        "Она впервые садится так, чтобы видеть тебя, а не воду — маленький, но заметный выбор."

    if get_affection("ivi") >= 60:
        $ renpy.notify("✨ Иви впервые сама предложила остаться. Что-то меняется.")
    else:
        $ renpy.notify("Иви смотрит тебе вслед из-за деревьев чуть дольше обычного.")

    hide ivi with dissolve
    jump return_to_map


# ----------------------------------------
# ФИНАЛЬНАЯ СЦЕНА (affection 60+)
# ----------------------------------------

label ivi_stage4:
    scene bg ivi with fade
    # play music "audio/music/ivi_music_30.mp3" fadein 2.0

    show ivi at center with dissolve

    $ _first_visit = not has_flag("ivi_stage4_seen")
    $ set_flag("ivi_stage4_seen")

    if _first_visit:
        "Вечер красит лес мягким золотом. Иви стоит у ручья без привычной сутулости — плечи расправлены, взгляд прямой, будто она наконец решила, что прятаться сегодня не будет."
        n "...Я долго решала, показывать тебе это место при закате или нет. Решила — да."

        "Золотой свет пробивается сквозь листья, и на секунду она перестаёт быть той, кто прячется — просто стоит, позволяя себя увидеть."

        n "...Не смотри так пристально. Я и так еле решилась."
    else:
        n "...Снова здесь. Хорошо, что ты рядом."

    $ reset_choices_if_exhausted("ivi", 4, 4)

    menu:
        "Ты не обязана ничего мне показывать. Мне достаточно тебя." if choice_open("ivi", 4, 0):
            $ use_choice("ivi", 4, 0)
            $ add_affection("ivi", 15)
            n "...Вот именно поэтому и решила. Ты не просишь. Странно, как это помогает."
            n "...Кажется, впервые в жизни мне не нужно ничего объяснять."

        "Можно взять тебя за руку?" if choice_open("ivi", 4, 1):
            $ use_choice("ivi", 4, 1)
            $ add_affection("ivi", 12)
            n "...Можно. Только не отпускай сразу. Я ещё не привыкла."
            n "...Тепло. Не думала, что это будет так просто."

        "Я никуда не тороплюсь. Мы можем просто побыть здесь." if choice_open("ivi", 4, 2):
            $ use_choice("ivi", 4, 2)
            $ add_affection("ivi", 18)
            n "...Спасибо. За то, что не торопишь. Это... непривычно приятно."
            n "...Кажется, я наконец перестала считать секунды до того, как захочу убежать."

        "Наконец-то ты открылась." if choice_open("ivi", 4, 3):
            $ use_choice("ivi", 4, 3)
            $ add_affection("ivi", -6)
            n "...'Наконец-то'? ...Как будто я была тебе что-то должна."
            n "...Дай мне право самой решать, когда это 'наконец'."

    if _first_visit:
        n "...Не уходи сразу. Я хочу запомнить, что ты был здесь до темноты."

    hide ivi with dissolve
    $ renpy.notify("🥝 Иви впервые вышла из тени полностью. Лес вокруг словно посветлел.")
    jump return_to_map
